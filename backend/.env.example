# Kenkoumon Backend - Environment Configuration

# =============================================================================
# API Keys (Optional - for cloud fallback)
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# =============================================================================
# AI Source Configuration
# =============================================================================
# Options: on-device, user-hosted, cloud
DEFAULT_TRANSCRIPTION_SOURCE=cloud
DEFAULT_LLM_SOURCE=cloud

# =============================================================================
# User-Hosted AI
# =============================================================================
OLLAMA_URL=http://localhost:11434

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=sqlite:///kenkoumon.db

# =============================================================================
# JWT Configuration
# =============================================================================
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =============================================================================
# CORS (Comma-separated list)
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,kenkoumon://

# =============================================================================
# File Storage
# =============================================================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100
