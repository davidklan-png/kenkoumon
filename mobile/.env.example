# Environment variables should NOT be committed to git.
# Copy this file to .env.local and .env.eas for EAS builds.

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_API_VERSION=v1

# AI Configuration
EXPO_PUBLIC_DEFAULT_TRANSCRIPTION_SOURCE=cloud
EXPO_PUBLIC_DEFAULT_LLM_SOURCE=cloud

# User-hosted AI (optional)
EXPO_PUBLIC_OLLAMA_URL=http://localhost:11434

# IMPORTANT: For EAS builds, use eas secret variables instead:
# eas secret:create OPENAI_API_KEY
# eas secret:create ANTHROPIC_API_KEY
